/*Create Tables*/
CREATE TABLE CUSTOMERS
(
	custID		char(50) PRIMARY KEY,
	firstName	char(50) not null,
	lastName	char(50) not null,
	city		char(50) not null,
	country		char(50) not null,
	phoneNUm	char(50) not null,
);

CREATE TABLE ORDERS
(
	orderID		int PRIMARY KEY,
	orderDate	date not null,
	orderTotal	money not null,
	custID		char(50) FOREIGN KEY REFERENCES CUSTOMERS(custID)
);

CREATE TABLE SUPPLIER
(
	companyName		char(100) PRIMARY KEY,
	contactName		char(100) not null,
	city			char(100) not null,
	county			char(100) not null,
	phoneNum		char(50) not null,
	fax				char(50) null,
	title			char(100) null
);


CREATE TABLE PRODUCTS
(
	productName		char(100) PRIMARY KEY,
	retailPrice		money not null,
	salePrice		money not null,
	packaging		char(100) not null,
	companyName		char(100) FOREIGN KEY REFERENCES SUPPLIER(companyName),
	isDiscontinued	int not null
);

CREATE TABLE ORDERITEMS
(
	orderID		int FOREIGN KEY REFERENCES ORDERS(orderID),
	quantity	int not null,
	productName	char(100) FOREIGN KEY REFERENCES PRODUCTS(productName),
	itemID		int PRIMARY KEY
);

