/*Queries*/
SELECT companyName FROM SUPPLIER
WHERE fax is NULL;

SELECT productName
FROM PRODUCTS
LEFT JOIN SUPPLIER
on PRODUCTS.companyName=SUPPLIER.companyName
WHERE SUPPLIER.fax is NULL AND PRODUCTS.retailPrice>40.00;

SELECT ORDERS.orderID, ORDERS.orderDate, CUSTOMERS.firstName as customerFirstName, CUSTOMERS.lastName as customerLastName, PRODUCTS.productName, ORDERITEMS.quantity, ORDERITEMS.quantity*PRODUCTS.salePrice as pricePaid
from ORDERS
JOIN CUSTOMERS
on ORDERS.custID=CUSTOMERS.custID
JOIN ORDERITEMS
on ORDERS.orderID=ORDERITEMS.orderID
JOIN PRODUCTS
on ORDERITEMS.productName=PRODUCTS.productName
Where orderTotal>4000.00;

SELECT firstName, lastName from CUSTOMERS
JOIN ORDERS
on CUSTOMERS.custID=ORDERS.custID
WHERE CUSTOMERS.country='France' and ORDERS.orderTotal>=1000.00;
